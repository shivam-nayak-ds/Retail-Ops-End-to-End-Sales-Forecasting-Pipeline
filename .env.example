# ─────────────────────────────────────────────
#  Retail-Ops Sales Forecasting Pipeline
#  Environment Variables Template
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── MLflow ──────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=retail-sales-forecasting
MLFLOW_MODEL_NAME=retail-forecaster

# ── ZenML ───────────────────────────────────
ZENML_STORE_URL=sqlite:///zenml.db

# ── Data Paths ──────────────────────────────
RAW_DATA_PATH=data/raw/train.csv
PROCESSED_DATA_PATH=data/processed/
ARTIFACTS_PATH=models/artifacts/

# ── Model Config ────────────────────────────
TARGET_COLUMN=Sales
DATE_COLUMN=Date
STORE_COLUMN=Store
TRAIN_SPLIT_RATIO=0.8

# ── API ─────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ── Monitoring ──────────────────────────────
DRIFT_THRESHOLD=0.15
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ── GenAI / RAG ─────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
VECTOR_STORE_PATH=models/vector_store/

# ── Alerts ──────────────────────────────────
SLACK_WEBHOOK_URL=your_slack_webhook_here
ALERT_EMAIL=your_email@example.com
